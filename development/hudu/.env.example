# Hudu Self-Hosted .env (Caddy-fronted variant).
#
# Copy to .env and fill in. Then generate the encryption secrets with:
#
#   openssl rand -hex 64    # SECRET_KEY_BASE
#   openssl rand -hex 16    # PASSWORD_KEY
#   openssl rand -hex 16    # TWO_FACTOR_KEY
#
# WARNING: once Hudu has been used, losing these three keys means losing
# access to every stored password and 2FA secret. Back up .env to a safe
# location (1Password, sops, etc.) immediately after first boot.

# ── Compose ───────────────────────────────────────
COMPOSE_PROJECT=hudu
DOMAIN=hudu.bmh.l.supported.systems

# ── Core (encryption keys — fill from openssl rand commands above) ──
SECRET_KEY_BASE=
PASSWORD_KEY=
TWO_FACTOR_KEY=

# ── Domain (LetsEncrypt vars — inert with DISABLE_SSL=true but kept for parity) ──
URL=bmh.l.supported.systems
SUBDOMAINS=hudu
ONLY_SUBDOMAINS=true
VALIDATION=http
STAGING=false

# ── TLS proxy mode (Caddy fronts us) ──────────────
DISABLE_SSL=true
BEHIND_TLS_PROXY=true

# ── Database ──────────────────────────────────────
DB_HOST=db
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=hudu_production
POSTGRES_HOST_AUTH_METHOD=trust
# ^ The wizard's default is `trust` (no password) since DB is internal-network
#   only. If you set DB_PASSWORD, change this to `scram-sha-256`.

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://redis

# ── SMTP (leave blank to skip outgoing mail; Hudu still works without it) ──
SMTP_DOMAIN=
SMTP_ADDRESS=
SMTP_PORT=
SMTP_STARTTLS_AUTO=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=
SMTP_OPENSSL_VERIFY_MODE=
SMTP_FROM_ADDRESS=

# ── Storage ───────────────────────────────────────
USE_LOCAL_FILESYSTEM=true
AUTHENTICATE_UPLOADS=true
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=

# ── Runtime ───────────────────────────────────────
PUID=1000
PGID=1000
RAILS_ENV=production
RACK_ENV=production
RAILS_MAX_THREADS=3
